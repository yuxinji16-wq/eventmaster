# EventMaster Pro backend environment template
# Copy to backend/.env for local development.

APP_NAME=EventMaster Pro API
DEBUG=true
API_V1_PREFIX=/api/v1

# SQLite is the default local database.
DATABASE_URL=sqlite:///./data/eventmaster.db

# MySQL example for non-local environments:
# DATABASE_URL=mysql+pymysql://user:password@localhost/eventmaster

# Change this value in every non-local environment.
SECRET_KEY=change-me-use-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional AI provider key used by backend integrations.
GOOGLE_API_KEY=

# Pydantic list syntax. Use explicit origins outside local development.
CORS_ORIGINS=["http://localhost:3000"]
