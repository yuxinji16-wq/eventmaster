# EventMaster Pro frontend environment template
# Copy to frontend/.env.local for local development.

VITE_API_BASE_URL=http://localhost:8001/api

# Preferred client-side Gemini key name for Vite.
VITE_GEMINI_API_KEY=

# Legacy compatibility: vite.config.ts also exposes this as process.env.GEMINI_API_KEY.
GEMINI_API_KEY=
